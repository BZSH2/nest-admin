{
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "$(capture).test.ts, $(capture).test.tsx, $(capture).spec.ts, $(capture).spec.tsx, $(capture).d.ts",
    "*.tsx": "$(capture).test.ts, $(capture).test.tsx, $(capture).spec.ts, $(capture).spec.tsx, $(capture).d.ts",
    "*.js": "$(capture).js.map, $(capture).spec.js, $(capture).test.js",
    "*.vue": "$(capture).js, $(capture).ts, $(capture).css, $(capture).scss, $(capture).less, $(capture).styl, $(capture).spec.js, $(capture).spec.ts, $(capture).test.js, $(capture).test.ts, $(capture).story.vue, $(capture).story.js, $(capture).story.ts",
    "package.json": "pnpm-lock.yaml, pnpm-workspace.yaml, .npmrc, .browserslistrc, .node-version, .nvmrc",
    "biome.json": ".gitattributes, .gitignore, .gitpod.yml, .editorconfig, tsconfig.*, jsconfig.*, cspell.json, commitlint.config.*, lint-staged.config.*, .czrc, jest.config.*",
    "README.md": "CHANGELOG*, LICENSE, CNAME, ICONS.md, TESTS.md, SECURITY.md",
    ".env": ".env.*, .envrc, env.d.ts",
    "vite.config.*": "vitest.config.*, playwright.config.*, uno.config.*, index.html",
    "eslint.config.*": ".prettierignore, .prettierrc.json, .stylelintignore, .oxlintrc.json, .oxfmtrc.json, stylelint.config.*, commitlint.config.*, lint-staged.config.*",
    "docker-compose.product.yml": ".dockerignore,nginx.conf"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}
